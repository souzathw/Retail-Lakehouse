# =========================
# Project
# =========================
PROJECT_NAME=retail-lakehouse
ENVIRONMENT=local

# =========================
# Airflow
# =========================
AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=./airflow
AIRFLOW_EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=True
AIRFLOW__API__AUTH_BACKENDS=airflow.api.auth.backend.basic_auth,airflow.api.auth.backend.session

# =========================
# Airflow Database
# =========================
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# =========================
# AWS
# =========================
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_DEFAULT_REGION=us-east-1
AWS_REGION=us-east-1

# =========================
# S3
# =========================
S3_BUCKET_RAW=your-retail-lakehouse-bucket
S3_BUCKET_BRONZE=your-retail-lakehouse-bucket
S3_BUCKET_SILVER=your-retail-lakehouse-bucket
S3_BUCKET_GOLD=your-retail-lakehouse-bucket
S3_PREFIX_RAW=raw/instacart
S3_PREFIX_BRONZE=bronze/instacart
S3_PREFIX_SILVER=silver/instacart
S3_PREFIX_GOLD=gold/instacart

# =========================
# Dataset
# =========================
DATASET_NAME=instacart
LOCAL_DATA_DIR=./data
LOCAL_RAW_DIR=./data/raw
LOCAL_BRONZE_DIR=./data/bronze
LOCAL_SILVER_DIR=./data/silver
LOCAL_GOLD_DIR=./data/gold

# =========================
# Spark
# =========================
SPARK_APP_NAME=retail-lakehouse-spark
SPARK_MASTER=local[*]
SPARK_DRIVER_MEMORY=2g
SPARK_EXECUTOR_MEMORY=2g

# =========================
# Athena
# =========================
ATHENA_DATABASE=retail_silver
ATHENA_OUTPUT_LOCATION=s3://your-retail-lakehouse-bucket/athena-query-results/

# =========================
# Redshift Serverless
# =========================
REDSHIFT_SERVERLESS_WORKGROUP=your-workgroup
REDSHIFT_SERVERLESS_NAMESPACE=your-namespace
REDSHIFT_DATABASE=dev
REDSHIFT_HOST=
REDSHIFT_PORT=5439
REDSHIFT_USER=
REDSHIFT_PASSWORD=

# =========================
# dbt
# =========================
DBT_PROJECT_DIR=./dbt/retail_analytics
DBT_PROFILES_DIR=./dbt/retail_analytics